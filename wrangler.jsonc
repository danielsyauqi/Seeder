{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "seeder",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  // Per-request CPU ceiling (Workers Paid). Caps worst-case compute per request
  // so a runaway invocation can't rack up CPU-time cost — it's killed instead.
  // 30s is the Paid default; well above normal page renders (tens of ms).
  "limits": {
    "cpu_ms": 30000
  },
  // App config is provided at runtime, never committed here:
  //   - locally via `.dev.vars` (copy `.dev.vars.example`)
  //   - in production via Worker vars/secrets (e.g. `wrangler secret put ...`)
  // Required: OWNER_EMAIL, BETTER_AUTH_SECRET. BETTER_AUTH_URL is required in
  // production; locally it defaults to the request origin when unset.
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "PM_DB",
      "database_name": "seeder",
      "database_id": "b9596b56-bb58-41be-bcf1-17e30426ec29",
      "preview_database_id": "b9596b56-bb58-41be-bcf1-17e30426ec29",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "seeder-uploads",
      "preview_bucket_name": "seeder-uploads"
    }
  ]
}
