# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.open-next

# production
/build

# local environment
.env*
!.env.example
.dev.vars*
!.dev.vars.example
.wrangler

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp cache
.playwright-mcp

# local agent / Claude Code files
.claude

# node-mode self-host artifacts (generated by `npm run setup`) — machine-specific,
# not for version control. ecosystem.config.cjs additionally carries
# BETTER_AUTH_SECRET; .env* is already ignored above.
ecosystem.config.cjs
seeder.service
Caddyfile
DEPLOY-node.md
/data/
/logs/

# Repo is npm-only; a stray bun.lock breaks Cloudflare Workers Builds detection
bun.lock
